        {
          "fullName": "",
          "functionType": "Action",
          "name": "doStepPreEvents",
          "sentence": "",
          "events": [
            {
              "type": "BuiltinCommonInstructions::JsCode",
              "inlineCode": [
                "// Updates the water shader uniforms\r",
                "function updateWaterUniforms(mesh, deltaTime) {\r",
                "    const mat = mesh.userData.waterMaterial;\r",
                "    if (!mat) return; // Stop if no water material is attached\r",
                "\r",
                "    // Update time (used to animate waves)\r",
                "    mat.uniforms.time.value += deltaTime;\r",
                "\r",
                "    // Wave displacement strength\r",
                "    mat.uniforms.displacementMultiplier.value = 0.01;\r",
                "}\r",
                "\r",
                "// Get the GDevelop object\r",
                "const gdjsObject = objects[0];\r",
                "\r",
                "// Retrieve the 3D mesh from the object\r",
                "const mesh = gdjsObject.get3DRendererObject();\r",
                "\r",
                "// deltaTime in seconds for smooth animations\r",
                "const deltaTime = runtimeScene.getElapsedTime() / 1000;\r",
                "\r",
                "// Apply uniform updates\r",
                "updateWaterUniforms(mesh, deltaTime);\r",
                ""
              ],
              "parameterObjects": "Object",
              "useStrict": true,
              "eventsSheetExpanded": true
            }
          ],
