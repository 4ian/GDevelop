      "eventsFunctions": [
        {
          "fullName": "",
          "functionType": "Action",
          "name": "onCreated",
          "sentence": "",
          "events": [
            {
              "type": "BuiltinCommonInstructions::JsCode",
              "inlineCode": [
                "if (objects.length > 0) {\r",
                "    const gdjsObject = objects[0];\r",
                "    const mesh = gdjsObject.get3DRendererObject();\r",
                "    const renderer = runtimeScene.getGame().getRenderer().getThreeRenderer();\r",
                "    const mainCamera = runtimeScene.getLayer()._renderer.getThreeCamera();\r",
                "\r",
                "    // Create enhanced water shader material\r",
                "    const waterMaterial = new THREE.ShaderMaterial({\r",
                "        side: THREE.DoubleSide,\r",
                "        transparent: true,\r",
                "        defines: {\r",
                "            ORTHOGRAPHIC_CAMERA: mainCamera.isOrthographicCamera ? 1 : 0\r",
                "        },\r",
                "        uniforms: {\r",
                "            time: { value: 0 },\r",
                "            // Enhanced color palette\r",
                "            foamColor: { value: new THREE.Color(0xffffff) },\r",
                "            waterColorShallow: { value: new THREE.Color(0x4dd0e1) }, // Cyan bright\r",
                "            waterColorDeep: { value: new THREE.Color(0x1565c0) }, // Deep blue\r",
                "            waterColorMid: { value: new THREE.Color(0x2196f3) }, // Mid blue\r",
                "            skyColor: { value: new THREE.Color(0x87ceeb) }, // Sky blue for reflections\r",
                "            \r",
                "            // Advanced parameters\r",
                "            displacementMultiplier: { value: 0.008 },\r",
                "            tiling: { value: 0.6 },\r",
                "            waveSpeed: { value: 1.0 },\r",
                "            waveHeight: { value: 0.3 },\r",
                "            foamIntensity: { value: 0.8 },\r",
                "            bubbleSpeed: { value: 0.5 },\r",
                "            bubbleDensity: { value: 0.3 },\r",
                "            shineIntensity: { value: 1.2 },\r",
                "            causticsIntensity: { value: 0.6 },\r",
                "            reflectionStrength: { value: 0.4 },\r",
                "            \r",
                "            cameraNear: { value: mainCamera.near },\r",
                "            cameraFar: { value: mainCamera.far }\r",
                "        },\r",
                "        vertexShader: `\r",
                "            varying vec2 vPlaneUV;\r",
                "            varying vec3 vWorldPosition;\r",
                "            varying vec3 vNormal;\r",
                "            varying vec3 vViewPosition;\r",
                "            \r",
                "            void main() {\r",
                "                vPlaneUV = position.xy;\r",
                "                vNormal = normalize(normalMatrix * normal);\r",
                "                \r",
                "                vec4 worldPosition = modelMatrix * vec4(position, 1.0);\r",
                "                vWorldPosition = worldPosition.xyz;\r",
                "                \r",
                "                vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);\r",
                "                vViewPosition = -mvPosition.xyz;\r",
                "                \r",
                "                gl_Position = projectionMatrix * mvPosition;\r",
                "            }\r",
                "        `,\r",
                "        fragmentShader: `\r",
                "            #include <common>\r",
                "            #include <packing>\r",
                "            \r",
                "            varying vec2 vPlaneUV;\r",
                "            varying vec3 vWorldPosition;\r",
                "            varying vec3 vNormal;\r",
                "            varying vec3 vViewPosition;\r",
                "            \r",
                "            uniform vec3 foamColor;\r",
                "            uniform vec3 waterColorShallow;\r",
                "            uniform vec3 waterColorDeep;\r",
                "            uniform vec3 waterColorMid;\r",
                "            uniform vec3 skyColor;\r",
                "            \r",
                "            uniform float cameraNear;\r",
                "            uniform float displacementMultiplier;\r",
                "            uniform float tiling;\r",
                "            uniform float cameraFar;\r",
                "            uniform float time;\r",
                "            uniform float waveSpeed;\r",
                "            uniform float waveHeight;\r",
                "            uniform float foamIntensity;\r",
                "            uniform float bubbleSpeed;\r",
                "            uniform float bubbleDensity;\r",
                "            uniform float shineIntensity;\r",
                "            uniform float causticsIntensity;\r",
                "            uniform float reflectionStrength;\r",
                "            \r",
                "            #define M_PI 3.14159265359\r",
                "            #define M_2PI 6.28318530718\r",
                "            \r",
                "            // Improved noise functions\r",
                "            float hash(vec2 p) {\r",
                "                return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);\r",
                "            }\r",
                "            \r",
                "            float noise(vec2 p) {\r",
                "                vec2 i = floor(p);\r",
                "                vec2 f = fract(p);\r",
                "                vec2 u = f * f * (3.0 - 2.0 * f);\r",
                "                \r",
                "                float a = hash(i);\r",
                "                float b = hash(i + vec2(1.0, 0.0));\r",
                "                float c = hash(i + vec2(0.0, 1.0));\r",
                "                float d = hash(i + vec2(1.0, 1.0));\r",
                "                \r",
                "                return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);\r",
                "            }\r",
                "            \r",
                "            // Multi-octave noise\r",
                "            float fbm(vec2 p, int octaves) {\r",
                "                float value = 0.0;\r",
                "                float amplitude = 0.5;\r",
                "                float frequency = 1.0;\r",
                "                \r",
                "                for(int i = 0; i < 8; i++) {\r",
                "                    if(i >= octaves) break;\r",
                "                    value += amplitude * noise(frequency * p);\r",
                "                    amplitude *= 0.5;\r",
                "                    frequency *= 2.0;\r",
                "                }\r",
                "                return value;\r",
                "            }\r",
                "            \r",
                "            // Voronoi cells for caustics effect\r",
                "            vec2 voronoi(vec2 p) {\r",
                "                vec2 i = floor(p);\r",
                "                vec2 f = fract(p);\r",
                "                \r",
                "                float minDist = 1.0;\r",
                "                vec2 minPoint;\r",
                "                \r",
                "                for(int y = -1; y <= 1; y++) {\r",
                "                    for(int x = -1; x <= 1; x++) {\r",
                "                        vec2 neighbor = vec2(float(x), float(y));\r",
                "                        vec2 point = hash(i + neighbor) * vec2(1.0) + neighbor;\r",
                "                        vec2 diff = point - f;\r",
                "                        float dist = length(diff);\r",
                "                        \r",
                "                        if(dist < minDist) {\r",
                "                            minDist = dist;\r",
                "                            minPoint = point;\r",
                "                        }\r",
                "                    }\r",
                "                }\r",
                "                \r",
                "                return vec2(minDist, hash(i + floor(minPoint)));\r",
                "            }\r",
                "            \r",
                "            // Caustics pattern\r",
                "            float caustics(vec2 uv, float time) {\r",
                "                vec2 p = uv * 4.0;\r",
                "                float t = time * 0.3;\r",
                "                \r",
                "                vec2 v1 = voronoi(p + t);\r",
                "                vec2 v2 = voronoi(p * 1.5 - t * 0.8);\r",
                "                \r",
                "                float pattern = v1.x * v2.x;\r",
                "                pattern = pow(pattern, 3.0);\r",
                "                return 1.0 - pattern;\r",
                "            }\r",
                "            \r",
                "            // Bubble generation\r",
                "            float bubble(vec2 uv, vec2 center, float radius, float time) {\r",
                "                float dist = length(uv - center);\r",
                "                float bubble = smoothstep(radius, radius * 0.8, dist);\r",
                "                float rim = smoothstep(radius * 0.6, radius * 0.5, dist);\r",
                "                return bubble * (1.0 - rim * 0.5);\r",
                "            }\r",
                "            \r",
                "            float bubbles(vec2 uv, float time) {\r",
                "                float result = 0.0;\r",
                "                float t = time * bubbleSpeed;\r",
                "                \r",
                "                // Multiple animated bubbles\r",
                "                for(float i = 0.0; i < 8.0; i++) {\r",
                "                    vec2 seed = vec2(i * 12.345, i * 67.89);\r",
                "                    float phase = hash(seed) * M_2PI;\r",
                "                    float speed = 0.3 + hash(seed + vec2(1.0)) * 0.4;\r",
                "                    \r",
                "                    vec2 center = vec2(\r",
                "                        hash(seed) * 2.0 - 1.0,\r",
                "                        mod(hash(seed + vec2(2.0)) - t * speed, 2.0) - 1.0\r",
                "                    );\r",
                "                    \r",
                "                    float radius = 0.02 + hash(seed + vec2(3.0)) * 0.04;\r",
                "                    float bubbleVal = bubble(uv, center, radius, t);\r",
                "                    \r",
                "                    // Add slight wobble to bubbles\r",
                "                    float wobble = sin(t * 3.0 + phase) * 0.01;\r",
                "                    bubbleVal *= 1.0 + wobble;\r",
                "                    \r",
                "                    result += bubbleVal * bubbleDensity;\r",
                "                }\r",
                "                \r",
                "                return clamp(result, 0.0, 1.0);\r",
                "            }\r",
                "            \r",
                "            // Dynamic waves\r",
                "            float waves(vec2 uv, float time) {\r",
                "                float t = time * waveSpeed;\r",
                "                vec2 p = uv * 3.0;\r",
                "                \r",
                "                float wave = 0.0;\r",
                "                wave += sin(p.x * 2.0 + t) * 0.5;\r",
                "                wave += sin(p.y * 3.0 - t * 0.8) * 0.3;\r",
                "                wave += sin((p.x + p.y) * 1.5 + t * 1.2) * 0.4;\r",
                "                wave += sin(length(p) * 4.0 - t * 1.5) * 0.2;\r",
                "                \r",
                "                return wave * waveHeight;\r",
                "            }\r",
                "            \r",
                "            // Foam pattern\r",
                "            float foam(vec2 uv, float time, float waveValue) {\r",
                "                float t = time * 0.5;\r",
                "                vec2 p = uv * 8.0;\r",
                "                \r",
                "                float foamPattern = fbm(p + t, 4);\r",
                "                foamPattern += fbm(p * 2.0 - t * 1.5, 3) * 0.5;\r",
                "                \r",
                "                // More foam on wave peaks\r",
                "                float peakFoam = smoothstep(0.2, 0.8, waveValue);\r",
                "                foamPattern = mix(foamPattern, 1.0, peakFoam * 0.3);\r",
                "                \r",
                "                return foamPattern;\r",
                "            }\r",
                "            \r",
                "            // Specular highlights\r",
                "            float specular(vec3 normal, vec3 viewDir, vec3 lightDir) {\r",
                "                vec3 halfDir = normalize(lightDir + viewDir);\r",
                "                float spec = pow(max(dot(normal, halfDir), 0.0), 32.0);\r",
                "                return spec;\r",
                "            }\r",
                "            \r",
                "            void main() {\r",
                "                vec2 worldUV = vPlaneUV * tiling;\r",
                "                float t = time;\r",
                "                \r",
                "                // Calculate waves\r",
                "                float waveValue = waves(worldUV, t);\r",
                "                \r",
                "                // Procedural DUDV distortion\r",
                "                vec2 dudvUV = worldUV * 0.3 + t * 0.05;\r",
                "                vec2 displacement = vec2(\r",
                "                    fbm(dudvUV, 4),\r",
                "                    fbm(dudvUV + vec2(1.7, 9.2), 4)\r",
                "                ) * 2.0 - 1.0;\r",
                "                \r",
                "                vec2 distortedUV = worldUV + displacement * displacementMultiplier;\r",
                "                \r",
                "                // Calculate normal from wave displacement for lighting\r",
                "                float eps = 0.01;\r",
                "                float waveX = waves(worldUV + vec2(eps, 0.0), t) - waveValue;\r",
                "                float waveY = waves(worldUV + vec2(0.0, eps), t) - waveValue;\r",
                "                vec3 waveNormal = normalize(vec3(-waveX / eps, -waveY / eps, 1.0));\r",
                "                \r",
                "                // Caustics\r",
                "                float causticsPattern = caustics(distortedUV, t) * causticsIntensity;\r",
                "                \r",
                "                // Bubbles\r",
                "                float bubblesPattern = bubbles(worldUV, t);\r",
                "                \r",
                "                // Foam\r",
                "                float foamPattern = foam(distortedUV, t, waveValue) * foamIntensity;\r",
                "                foamPattern = smoothstep(0.6, 0.9, foamPattern);\r",
                "                \r",
                "                // Color mixing based on depth and waves\r",
                "                float depthFactor = clamp(waveValue * 0.5 + 0.5, 0.0, 1.0);\r",
                "                vec3 waterColor = mix(waterColorDeep, waterColorMid, depthFactor);\r",
                "                waterColor = mix(waterColor, waterColorShallow, pow(depthFactor, 2.0));\r",
                "                \r",
                "                // Apply caustics\r",
                "                waterColor += waterColor * causticsPattern * 0.5;\r",
                "                \r",
                "                // View direction for reflections\r",
                "                vec3 viewDir = normalize(vViewPosition);\r",
                "                vec3 lightDir = normalize(vec3(0.5, 1.0, 0.3));\r",
                "                \r",
                "                // Fresnel effect for reflections\r",
                "                float fresnel = pow(1.0 - max(dot(waveNormal, viewDir), 0.0), 3.0);\r",
                "                vec3 reflectionColor = mix(skyColor, waterColorShallow, 0.3);\r",
                "                waterColor = mix(waterColor, reflectionColor, fresnel * reflectionStrength);\r",
                "                \r",
                "                // Specular highlights\r",
                "                float spec = specular(waveNormal, viewDir, lightDir) * shineIntensity;\r",
                "                waterColor += vec3(spec) * 0.8;\r",
                "                \r",
                "                // Add bubbles (white highlights)\r",
                "                waterColor = mix(waterColor, vec3(1.0), bubblesPattern * 0.7);\r",
                "                \r",
                "                // Add foam\r",
                "                waterColor = mix(waterColor, foamColor, foamPattern);\r",
                "                \r",
                "                // Edge foam (optional - adds foam near edges)\r",
                "                float edgeFoam = smoothstep(0.9, 1.0, abs(vPlaneUV.x)) + \r",
                "                                 smoothstep(0.9, 1.0, abs(vPlaneUV.y));\r",
                "                waterColor = mix(waterColor, foamColor, edgeFoam * 0.3);\r",
                "                \r",
                "                // Final color with enhanced brightness\r",
                "                vec3 finalColor = waterColor * 1.1;\r",
                "                \r",
                "                // Dynamic transparency based on foam and depth\r",
                "                float alpha = 0.75 + foamPattern * 0.2 - depthFactor * 0.1;\r",
                "                alpha = clamp(alpha, 0.6, 0.95);\r",
                "                \r",
                "                gl_FragColor = vec4(finalColor, alpha);\r",
                "                \r",
                "                #include <tonemapping_fragment>\r",
                "                #include <colorspace_fragment>\r",
                "            }\r",
                "        `\r",
                "    });\r",
                "\r",
                "    // Apply material recursively\r",
                "    function applyMaterialRecursive(object3D, waterMaterial) {\r",
                "        object3D.traverse(child => {\r",
                "            if (child.isMesh) {\r",
                "                if (Array.isArray(child.material)) {\r",
                "                    child.material = child.material.map(() => waterMaterial);\r",
                "                } else {\r",
                "                    child.material = waterMaterial;\r",
                "                }\r",
                "                child.needsUpdate = true;\r",
                "            }\r",
                "        });\r",
                "    }\r",
                "\r",
                "    applyMaterialRecursive(mesh, waterMaterial);\r",
                "\r",
                "    // Store references for animation\r",
                "    mesh.userData.waterMaterial = waterMaterial;\r",
                "    mesh.userData.mainCamera = mainCamera;\r",
                "}\r",
                "\r",
                "// ===== ANIMATION SCRIPT (Add this to a separate \"For each object\" event) =====\r",
                "// This should run every frame to animate the water\r",
                "\r",
                "if (objects.length > 0) {\r",
                "    const gdjsObject = objects[0];\r",
                "    const mesh = gdjsObject.get3DRendererObject();\r",
                "    \r",
                "    if (mesh.userData.waterMaterial) {\r",
                "        // Update time uniform for animation\r",
                "        mesh.userData.waterMaterial.uniforms.time.value += 0.016; // ~60fps\r",
                "    }\r",
                "}"
              ],
              "parameterObjects": "Object",
              "useStrict": true,
              "eventsSheetExpanded": true
            }
          ],
          "parameters": [
